ENV=dev
LOG_LEVEL=INFO
BACKEND_URL=http://localhost:8000

# Neon Postgres — copy into repo-root `.env` for Docker Compose and `backend/.env` for local uvicorn.
# DATABASE_URL uses the asyncpg dialect for the FastAPI backend runtime.
# DIRECT_URL is the non-pooled (direct) Neon endpoint for Alembic migrations.
# PRISMA_DATABASE_URL is the plain postgresql:// URL for the frontend Prisma client (pooled is fine).
# For `frontend/.env.local`, set DATABASE_URL=<plain postgresql://...> (no +asyncpg prefix).
# DATABASE_URL=postgresql+asyncpg://...@...neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://...@...neon.tech/neondb?sslmode=require
# PRISMA_DATABASE_URL=postgresql://...@...-pooler.neon.tech/neondb?sslmode=require

# S3 / Parquet (optional bucket; unset = local-only reads via ParquetStore)
# S3_BUCKET=your-public-read-parquet-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=http://localhost:4566
# PARQUET_LOCAL_FALLBACK_DIR=data/parquet
