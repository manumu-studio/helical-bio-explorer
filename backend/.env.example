# Backend environment template. Copy to `.env` and fill in.
# Parsed by app.core.config.Settings (pydantic-settings).

# Runtime ----------------------------------------------------------------
ENV=dev                  # dev | prod
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# Neon Postgres ----------------------------------------------------------
# DATABASE_URL: pooled endpoint (asyncpg) used by FastAPI at runtime.
# DIRECT_URL:   direct (non-pooled) endpoint used by Alembic for migrations.
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASS@HOST/DB?sslmode=require

# CORS -------------------------------------------------------------------
# JSON array — pydantic-settings parses this form from env.
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Parquet / S3 (ADR-005) -------------------------------------------------
# Leave S3_BUCKET unset to skip S3 and rely on the local fallback only.
# S3_BUCKET=helical-bio-explorer-artifacts
S3_REGION=us-east-1
# S3_ENDPOINT_URL=           # only set when hitting moto or a custom endpoint
PARQUET_LOCAL_FALLBACK_DIR=data/parquet
